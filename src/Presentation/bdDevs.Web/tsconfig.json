{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./wwwroot/js/dist",
    "rootDir": "./ts-src",
    "baseUrl": "./ts-src",
    "paths": {
      "@core/*": [ "core/*" ],
      "@services/*": [ "services/*" ],
      "@types/*": [ "types/*" ]
    }
  },
  "include": [ "ts-src/**/*" ],
  "exclude": [ "node_modules", "wwwroot" ]
}