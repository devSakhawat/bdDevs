@* ╔══════════════════════════════════════════════════════════════════
   ║  _GridPageShell.cshtml — Reusable Grid Page Template
   ║
   ║  Usage in a view:
   ║
   ║  @{
   ║      ViewData["Title"] = "Lead List";
   ║      ViewData["Module"] = "CRM";
   ║      ViewData["BreadcrumbItems"] = new List<BreadcrumbItem>
   ║      {
   ║          new("CRM", "/crm"),
   ║          new("Leads", null)
   ║      };
   ║      Layout = "~/Views/Shared/_Layout.cshtml";
   ║  }
   ║
   ║  @section PageActions {
   ║      <button class="bd-btn bd-btn-primary" id="btnNew">
   ║          + New Lead
   ║      </button>
   ║  }
   ║
   ║  @await Html.PartialAsync("~/Views/Templates/_GridPageShell.cshtml")
   ║
   ║  @section Scripts {
   ║      <script>/* grid init */</script>
   ║  }
   ╚══════════════════════════════════════════════════════════════════ *@

@{
    var gridId = ViewData["GridId"]?.ToString() ?? "bdMainGrid";
    var gridTitle = ViewData["Title"]?.ToString() ?? "Records";
}

<div class="bd-grid-page">

    <!-- ── TOOLBAR ── -->
    <div class="bd-grid-toolbar" id="bdGridToolbar">

        <!-- Left: Search + Filter -->
        <div class="bd-grid-toolbar-left">
            <div class="bd-grid-search-wrap">
                <svg class="bd-grid-search-icon" width="16" height="16" viewBox="0 0 20 20"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="8.5" cy="8.5" r="5.5"/>
                    <path d="M15 15l-3-3"/>
                </svg>
                <input type="text"
                       class="bd-grid-search"
                       id="bdGridSearch"
                       placeholder="Search @gridTitle..."
                       autocomplete="off" />
                <button class="bd-grid-search-clear" id="bdGridSearchClear" style="display:none;" title="Clear search">✕</button>
            </div>

            <button class="bd-toolbar-btn" id="bdFilterBtn" title="Filter">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 5h16M5 10h10M8 15h4"/>
                </svg>
                Filter
                <span class="bd-filter-count" id="bdFilterCount" style="display:none;">0</span>
            </button>
        </div>

        <!-- Right: Actions -->
        <div class="bd-grid-toolbar-right">

            <!-- Bulk actions (shown on multi-select) -->
            <div class="bd-bulk-actions" id="bdBulkActions" style="display:none;">
                <span class="bd-bulk-count"><span id="bdSelectedCount">0</span> selected</span>
                <button class="bd-toolbar-btn bd-toolbar-btn--danger" id="bdBulkDelete" title="Delete selected">
                    <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 17 6"/>
                        <path d="M8 6V4h4v2M19 6l-1 12a2 2 0 01-2 2H4a2 2 0 01-2-2L1 6"/>
                    </svg>
                    Delete
                </button>
                <button class="bd-toolbar-btn" id="bdBulkExport" title="Export selected">
                    <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 16v1a2 2 0 002 2h8a2 2 0 002-2v-1M7 10l3 3 3-3M10 3v10"/>
                    </svg>
                    Export
                </button>
                <button class="bd-toolbar-btn bd-bulk-clear" id="bdBulkClear" title="Clear selection">✕</button>
            </div>

            <!-- Column chooser -->
            <button class="bd-toolbar-btn bd-toolbar-btn--icon" id="bdColumnChooser" title="Choose columns">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="5" height="14" rx="1"/>
                    <rect x="9" y="3" width="5" height="14" rx="1"/>
                    <rect x="16" y="3" width="2" height="14" rx="1"/>
                </svg>
            </button>

            <!-- Export dropdown -->
            <div class="bd-export-wrap">
                <button class="bd-toolbar-btn" id="bdExportBtn" title="Export">
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 16v1a2 2 0 002 2h8a2 2 0 002-2v-1M7 10l3 3 3-3M10 3v10"/>
                    </svg>
                    Export
                    <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M6 8l4 4 4-4"/>
                    </svg>
                </button>
                <div class="bd-export-menu" id="bdExportMenu" style="display:none;">
                    <button class="bd-export-item" data-format="excel">Excel (.xlsx)</button>
                    <button class="bd-export-item" data-format="pdf">PDF</button>
                    <button class="bd-export-item" data-format="csv">CSV</button>
                </div>
            </div>

            <!-- Refresh -->
            <button class="bd-toolbar-btn bd-toolbar-btn--icon" id="bdRefreshGrid" title="Refresh">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4v5h5M20 20v-5h-5"/>
                    <path d="M1 11.5a9 9 0 1017.9-1.4"/>
                </svg>
            </button>

            <!-- New button (page-level, from PageActions section) -->
            @await RenderSectionAsync("GridActions", required: false)

        </div>
    </div>

    <!-- ── KENDO GRID ── -->
    <div class="bd-grid-wrap">
        <div id="@gridId"></div>
    </div>

</div>
