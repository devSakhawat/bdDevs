@{
    ViewData["Title"] = "Menu Management";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Menu Management</h2>
        <button type="button" class="btn btn-primary" id="btnAddMenu">
            <i class="bi bi-plus-circle"></i> Add New Menu
        </button>
    </div>

    <!-- Menu Grid -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="menuTable">
                    <thead class="table-light">
                        <tr>
                            <th>Menu ID</th>
                            <th>Menu Name</th>
                            <th>Module ID</th>
                            <th>Menu Path</th>
                            <th>Parent Menu</th>
                            <th>Sort Order</th>
                            <th>Active</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="menuTableBody">
                        <!-- Dynamic content will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Menu Modal -->
<div class="modal fade" id="menuModal" tabindex="-1" aria-labelledby="menuModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="menuModalLabel">Add Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="menuForm">
                    <input type="hidden" id="menuId" name="menuId">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="menuName" class="form-label">Menu Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="menuName" name="menuName" maxlength="50" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="moduleId" class="form-label">Module ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="moduleId" name="moduleId" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="menuPath" class="form-label">Menu Path</label>
                            <input type="text" class="form-control" id="menuPath" name="menuPath" maxlength="200" placeholder="/path/to/page">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="parentMenu" class="form-label">Parent Menu ID</label>
                            <input type="number" class="form-control" id="parentMenu" name="parentMenu" placeholder="Leave empty for root menu">
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="sororder" class="form-label">Sort Order</label>
                            <input type="number" class="form-control" id="sororder" name="sororder" value="0">
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="isActive" class="form-label">Status</label>
                            <select class="form-select" id="isActive" name="isActive">
                                <option value="1">Active</option>
                                <option value="0">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="todo" class="form-label">TODO Count</label>
                            <input type="number" class="form-control" id="todo" name="todo" value="0">
                            <small class="form-text text-muted">Badge counter for pending items</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveMenu">Save Menu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/menu-management.js"></script>
}
