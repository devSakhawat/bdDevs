@*
    Command Palette Component
    Provides a Ctrl+K quick command search for navigation and actions
*@

<!-- Command Palette Backdrop -->
<div id="bdCpBackdrop" class="bd-cp-backdrop" style="display:none;"></div>

<!-- Command Palette -->
<div id="bdCommandPalette" class="bd-command-palette" style="display:none;" role="dialog" aria-label="Command Palette">

    <!-- Search Input -->
    <div class="bd-cp-input-wrap">
        <span class="bd-cp-search-icon">🔍</span>
        <input
            type="text"
            id="bdCpInput"
            class="bd-cp-input"
            placeholder="Type a command or search..."
            autocomplete="off"
            aria-label="Search commands"
        />
        <kbd class="bd-cp-esc-hint">ESC</kbd>
    </div>

    <!-- Results Container -->
    <div class="bd-cp-results" role="listbox">

        <!-- Recent Commands Section -->
        <div id="bdCpRecent" class="bd-cp-section" style="display:none;">
            <div class="bd-cp-section-label">Recent</div>
            <div id="bdCpRecentItems"></div>
        </div>

        <!-- All Commands Section -->
        <div id="bdCpCommands" class="bd-cp-section">
            <div class="bd-cp-section-label">Commands</div>
            <div id="bdCpCommandItems"></div>
        </div>

        <!-- Empty State -->
        <div id="bdCpEmpty" class="bd-cp-empty" style="display:none;">
            <div>❌</div>
            <p>No results found for "<span id="bdCpQuery"></span>"</p>
        </div>
    </div>

    <!-- Footer with Hints -->
    <div class="bd-cp-footer">
        <span><kbd>↑</kbd> <kbd>↓</kbd> to navigate</span>
        <span><kbd>Enter</kbd> to select</span>
        <span><kbd>ESC</kbd> to close</span>
    </div>

</div>
