@using bdDevs.Contracts.Responses
@using bdDevs.Web.Services
@inject WebMenuService MenuService

@{
  var menu = await MenuService.GetMenuAsync();
  var currentUrl = Context.Request.Path.Value ?? "";
}

<nav id="sidebar" class="sidebar">
  <div class="sidebar-header">
    <a class="sidebar-brand" href="/dashboard">
      <span class="brand-icon"><i class="fa-solid fa-building"></i></span>
      <span class="brand-text">bdDevs</span>
    </a>
    <button id="sidebarToggle" class="btn btn-link sidebar-toggle">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>

  <div class="sidebar-search">
    <input type="text" id="menuSearch"
           placeholder="Search menu... (Ctrl+K)"
           class="form-control form-control-sm" />
  </div>

  <ul class="sidebar-nav" id="sidebarNav">
    @foreach (var item in menu)
    {
      if (item.IsGroup && item.HasChildren)
      {
        <!-- Group with children -->
        <li class="nav-group">
          <a class="nav-group-toggle @(IsActiveGroup(item, currentUrl) ? "active" : "")"
             href="#group-@item.Id"
             data-bs-toggle="collapse">
            <i class="fa-solid @item.Icon me-2"></i>
            <span class="nav-text">@item.Title</span>
            <i class="fa-solid fa-chevron-down ms-auto nav-arrow"></i>
          </a>
          <ul class="nav-group-items collapse @(IsActiveGroup(item, currentUrl) ? "show" : "")"
              id="group-@item.Id">
            @foreach (var child in item.Children.OrderBy(c => c.SortOrder))
            {
              <li class="nav-item">
                <a class="nav-link @(currentUrl.StartsWith(child.Url ?? "") ? "active" : "")"
                   href="@child.Url"
                   data-partial="true">
                  <i class="fa-solid @child.Icon me-2"></i>
                  <span class="nav-text">@child.Title</span>
                </a>
              </li>
            }
          </ul>
        </li>
      }
      else if (!item.IsGroup)
      {
        <!-- Direct link -->
        <li class="nav-item">
          <a class="nav-link @(currentUrl == item.Url ? "active" : "")"
             href="@item.Url"
             data-partial="true">
            <i class="fa-solid @item.Icon me-2"></i>
            <span class="nav-text">@item.Title</span>
          </a>
        </li>
      }
    }
  </ul>
</nav>

@functions {
  bool IsActiveGroup(MenuItemDto group, string url) =>
      group.Children.Any(c => url.StartsWith(c.Url ?? "~~"));
}