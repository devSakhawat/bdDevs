@* ╔══════════════════════════════════════════════════════════╗
   ║  _Topbar.cshtml — Fixed 80px topbar                     ║
   ║  Left → Right:                                          ║
   ║  [Logo/brand][Toggle] | [Breadcrumb] | [Search][Bell]  ║
   ║                                       [Settings][Theme]║
   ║                                       [Avatar]         ║
   ╚══════════════════════════════════════════════════════════╝ *@

<header class="bd-topbar" id="bdTopbar" role="banner">

    <!-- ── LEFT: Logo + Sidebar Toggle ── -->
    <div class="bd-topbar-left">
        <div class="bd-brand">
            <a href="/" class="bd-brand-link" aria-label="bdDevs Home">
                <div class="bd-brand-icon">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="28" height="28" rx="6" fill="var(--bd-accent)"/>
                        <text x="6" y="20" font-family="sans-serif" font-size="14" font-weight="700" fill="white">bd</text>
                    </svg>
                </div>
                <span class="bd-brand-name">bdDevs</span>
            </a>
        </div>
        <button class="bd-sidebar-toggle" id="bdSidebarToggle"
                aria-label="Toggle sidebar" aria-expanded="true"
                title="Toggle Sidebar (Ctrl+B)">
            <span class="bd-toggle-bar"></span>
            <span class="bd-toggle-bar"></span>
            <span class="bd-toggle-bar"></span>
        </button>
    </div>

    <!-- ── CENTER: Breadcrumb ── -->
    <div class="bd-topbar-center">
        @await Html.PartialAsync("_Breadcrumb")
    </div>

    <!-- ── RIGHT: Actions ── -->
    <div class="bd-topbar-right">

        <!-- Global Search / Command Palette trigger -->
        <button class="bd-search-trigger" id="bdSearchTrigger"
                aria-label="Search or run command (Ctrl+K)"
                title="Search or Command (Ctrl+K)">
            <svg class="bd-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="8.5" cy="8.5" r="5.5"/>
                <path d="M15 15l-3-3"/>
            </svg>
            <span class="bd-search-label">Search...</span>
            <kbd class="bd-kbd">⌘K</kbd>
        </button>

        <!-- Notification Bell -->
        <button class="bd-topbar-btn bd-notification-btn" id="bdNotificationBtn"
                aria-label="Notifications" aria-haspopup="true" aria-expanded="false"
                title="Notifications">
            <svg class="bd-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 10a5 5 0 00-10 0v3l-1.5 2.5h13L15 13v-3z"/>
                <path d="M10 18a2 2 0 004 0"/>
            </svg>
            <span class="bd-badge" id="bdNotificationBadge" style="display:none;">0</span>
        </button>

        <!-- Theme Switcher -->
        <button class="bd-topbar-btn bd-theme-btn" id="bdThemeBtn"
                aria-label="Theme settings" aria-haspopup="true"
                title="Theme & Appearance">
            <svg class="bd-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="10" cy="10" r="4"/>
                <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.22 4.22l1.42 1.42M14.36 14.36l1.42 1.42M4.22 15.78l1.42-1.42M14.36 5.64l1.42-1.42"/>
            </svg>
        </button>

        <!-- Theme Picker Panel -->
        <div class="bd-theme-panel" id="bdThemePanel" role="dialog" aria-label="Theme settings" style="display:none;">
            <div class="bd-theme-panel-header">
                <span>Appearance</span>
                <button class="bd-theme-panel-close" id="bdThemePanelClose" aria-label="Close">✕</button>
            </div>
            <div class="bd-theme-section">
                <label class="bd-theme-label">Theme Family</label>
                <div class="bd-theme-chips" id="bdThemeFamilyChips">
                    <button class="bd-chip active" data-family="default">Default</button>
                    <button class="bd-chip" data-family="bootstrap">Bootstrap</button>
                    <button class="bd-chip" data-family="material">Material</button>
                    <button class="bd-chip" data-family="fluent">Fluent</button>
                </div>
            </div>
            <div class="bd-theme-section">
                <label class="bd-theme-label">Mode</label>
                <div class="bd-theme-chips" id="bdThemeModeChips">
                    <button class="bd-chip active" data-mode="light">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="10" cy="10" r="4"/>
                            <path d="M10 2v2M10 16v2M2 10h2M16 10h2"/>
                        </svg>
                        Light
                    </button>
                    <button class="bd-chip" data-mode="dark">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
                        </svg>
                        Dark
                    </button>
                </div>
            </div>
            <div class="bd-theme-section">
                <label class="bd-theme-label">Density</label>
                <div class="bd-theme-chips" id="bdThemeDensityChips">
                    <button class="bd-chip" data-density="compact">Compact</button>
                    <button class="bd-chip active" data-density="comfortable">Comfortable</button>
                </div>
            </div>
        </div>

        <!-- Settings Dropdown -->
        <button class="bd-topbar-btn bd-settings-btn" id="bdSettingsBtn"
                aria-label="Settings" aria-haspopup="true"
                title="Settings">
            <svg class="bd-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="10" cy="10" r="2"/>
                <path d="M10 2C5.58 2 2 5.58 2 10s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8z"/>
                <path d="M10 6V2M10 18v-4M6 10H2M18 10h-4"/>
            </svg>
        </button>

        <!-- Settings Dropdown Menu -->
        <div class="bd-dropdown-menu" id="bdSettingsMenu" style="display:none;">
            <a class="bd-dropdown-item" href="/account/profile">
                <svg class="bd-icon-sm" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="10" cy="7" r="3"/>
                    <path d="M3 19c0-3.87 3.13-7 7-7s7 3.13 7 7"/>
                </svg>
                My Profile
            </a>
            <a class="bd-dropdown-item" href="/account/change-password">
                <svg class="bd-icon-sm" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="9" width="14" height="10" rx="2"/>
                    <path d="M7 9V7a3 3 0 016 0v2"/>
                </svg>
                Change Password
            </a>
            <div class="bd-dropdown-divider"></div>
            <a class="bd-dropdown-item" href="/account/preferences">
                <svg class="bd-icon-sm" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="10" cy="10" r="3"/>
                    <path d="M10 2v2M10 16v2M2 10h2M16 10h2"/>
                </svg>
                Preferences
            </a>
            <div class="bd-dropdown-divider"></div>
            <button class="bd-dropdown-item bd-dropdown-item--danger" id="bdLogoutBtn">
                <svg class="bd-icon-sm" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 3h4a1 1 0 011 1v12a1 1 0 01-1 1h-4"/>
                    <path d="M9 15l-4-5 4-5M15 10H5"/>
                </svg>
                Logout
            </button>
        </div>

        <!-- User Avatar -->
        <button class="bd-avatar-btn" id="bdAvatarBtn"
                aria-label="User menu" aria-haspopup="true">
            <div class="bd-avatar" id="bdUserAvatar">
                <span id="bdUserInitials">?</span>
            </div>
            <div class="bd-user-info">
                <span class="bd-user-name" id="bdUserName">Loading...</span>
            </div>
        </button>

        <!-- User Dropdown -->
        <div class="bd-dropdown-menu bd-user-menu" id="bdUserMenu" style="display:none;">
            <div class="bd-dropdown-header">
                <div class="bd-avatar bd-avatar--lg">
                    <span id="bdUserInitialsMenu">?</span>
                </div>
                <div>
                    <div class="bd-user-name-lg" id="bdUserNameMenu">–</div>
                    <div class="bd-user-email" id="bdUserEmailMenu">–</div>
                </div>
            </div>
            <div class="bd-dropdown-divider"></div>
            <a class="bd-dropdown-item" href="/account/profile">My Profile</a>
            <a class="bd-dropdown-item" href="/account/preferences">Preferences</a>
            <div class="bd-dropdown-divider"></div>
            <button class="bd-dropdown-item bd-dropdown-item--danger" id="bdLogoutBtn2">
                Logout
            </button>
        </div>

    </div>
</header>
