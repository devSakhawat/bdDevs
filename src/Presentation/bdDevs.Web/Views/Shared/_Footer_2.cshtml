@* ── Fixed 50px footer ── *@
<footer class="bd-footer" id="bdFooter" role="contentinfo">
    <div class="bd-footer-left">
        <span class="bd-footer-brand">bdDevs</span>
        <span class="bd-footer-sep">·</span>
        <span class="bd-footer-copy">&copy; @DateTime.Now.Year bdDev</span>
    </div>
    <div class="bd-footer-center">
        <span class="bd-footer-status" id="bdFooterStatus">
            <span class="bd-status-dot bd-status-dot--online" title="System Online"></span>
            All systems operational
        </span>
    </div>
    <div class="bd-footer-right">
        <span class="bd-footer-version" id="bdFooterVersion">v1.0.0</span>
        <span class="bd-footer-sep">·</span>
        <span class="bd-footer-env" id="bdFooterEnv">@(System.Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Production")</span>
    </div>
</footer>
